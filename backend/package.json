{
  "name": "hospital-management-backend",
  "version": "1.0.0",
  "description": "Hospital Management System Backend",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "cross-env PORT=5001 nodemon src/server.js",
    "start": "cross-env PORT=5001 node src/server.js",
    "prisma:generate": "prisma generate --config prisma.config.js",
    "prisma:migrate": "prisma migrate dev --config prisma.config.js",
    "prisma:push": "prisma db push --config prisma.config.js",
    "prisma:studio": "prisma studio --config prisma.config.js",
    "seed": "node prisma/seed.js"
  },
  "keywords": [
    "hospital",
    "management",
    "system",
    "healthcare",
    "prisma",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.2",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.11",
    "prisma": "^6.19.2"
  }
}
